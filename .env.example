# ──────────────────────────────────────────────────────────────
# StadiumPulse AI — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values:
#   copy .env.example .env
#
# NEVER commit .env to version control — it contains secrets.
# ──────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
APP_NAME="StadiumPulse AI"
APP_VERSION="0.1.0"
DEBUG=true

# ── Database ─────────────────────────────────────────────────
# SQLite for development. For production, use:
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/stadiumPulse
DATABASE_URL=sqlite+aiosqlite:///./stadiumPulse.db

# ── Gemini AI ────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite

# ── CORS ─────────────────────────────────────────────────────
# Allowed frontend origins (JSON array format)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/api/v1/ws/crowd

# ── Rate Limiting ────────────────────────────────────────────
# Format: "requests/period" — controls Gemini API spend and abuse
RATE_LIMIT_CHAT=10/minute
